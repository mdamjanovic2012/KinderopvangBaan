{
  "info": {
    "name": "KinderopvangBaan API",
    "description": "Integration tests for the KinderopvangBaan Django REST API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "{{BASE_URL}}",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "refresh_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "institution_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "job_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "worker_username",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Jobs list is accessible",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/jobs/"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has results array', () => pm.expect(pm.response.json().results).to.be.an('array'));",
                  "pm.test('Has count or total', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.total !== undefined || body.count !== undefined).to.be.true;",
                  "});",
                  "if (pm.response.json().results.length > 0) {",
                  "  pm.collectionVariables.set('job_id', pm.response.json().results[0].id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Companies list is accessible",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/jobs/companies/"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns array or paginated', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(Array.isArray(body) || Array.isArray(body.results)).to.be.true;",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth \u2014 Register",
      "item": [
        {
          "name": "Register worker",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register/",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\": \"newman_w_{{$randomInt}}\", \"email\": \"w_{{$randomInt}}@test.nl\", \"password\": \"testpass123\", \"role\": \"worker\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('Returns user data with role', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('id');",
                  "  pm.expect(body.role).to.eql('worker');",
                  "});",
                  "pm.test('No password in response', () => pm.expect(pm.response.json()).to.not.have.property('password'));",
                  "pm.collectionVariables.set('worker_username', pm.response.json().username);"
                ]
              }
            }
          ]
        },
        {
          "name": "Register \u2014 short password rejected",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register/",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\": \"badpw_{{$randomInt}}\", \"password\": \"abc\", \"role\": \"worker\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth \u2014 Token",
      "item": [
        {
          "name": "Obtain JWT token",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/token/",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\": \"{{worker_username}}\", \"password\": \"testpass123\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns access and refresh tokens', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('access');",
                  "  pm.expect(body).to.have.property('refresh');",
                  "});",
                  "pm.collectionVariables.set('access_token', pm.response.json().access);",
                  "pm.collectionVariables.set('refresh_token', pm.response.json().refresh);"
                ]
              }
            }
          ]
        },
        {
          "name": "Wrong password returns 401",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/token/",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\": \"{{worker_username}}\", \"password\": \"wrongpassword\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh access token",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/token/refresh/",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"refresh\": \"{{refresh_token}}\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns new access token', () => pm.expect(pm.response.json()).to.have.property('access'));",
                  "pm.collectionVariables.set('access_token', pm.response.json().access);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth \u2014 Me & Profile",
      "item": [
        {
          "name": "GET /me/ \u2014 authenticated",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/me/",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns username', () => {",
                  "  pm.expect(pm.response.json().username).to.eql(pm.collectionVariables.get('worker_username'));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /me/ \u2014 unauthenticated returns 401",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/me/"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ]
        },
        {
          "name": "GET worker-profile",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/worker-profile/",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has work_radius_km', () => pm.expect(pm.response.json()).to.have.property('work_radius_km'));"
                ]
              }
            }
          ]
        },
        {
          "name": "PATCH worker-profile",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/auth/worker-profile/",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"bio\": \"Newman test bio\", \"work_radius_km\": 20, \"has_vog\": true}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Bio updated', () => pm.expect(pm.response.json().bio).to.eql('Newman test bio'));",
                  "pm.test('work_radius_km 20', () => pm.expect(pm.response.json().work_radius_km).to.eql(20));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        {
          "name": "Filter by contract_type=fulltime",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/jobs/?contract_type=fulltime"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('All results are fulltime', () => {",
                  "  pm.response.json().results.forEach(j => pm.expect(j.contract_type).to.eql('fulltime'));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get job detail",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/jobs/{{job_id}}/"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has required fields', () => {",
                  "  ['id','title','company_name','source_url','city'].forEach(f => {",
                  "    pm.expect(pm.response.json()).to.have.property(f);",
                  "  });",
                  "});"
                ]
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const jobId = pm.collectionVariables.get('job_id');",
                  "if (!jobId) { pm.execution.skipRequest(); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Nearby jobs \u2014 Amsterdam 100km",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/jobs/nearby/?lat=52.3676&lng=4.9041&radius=100"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has results array', () => pm.expect(pm.response.json().results).to.be.an('array'));",
                  "pm.test('Has count or total', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.total !== undefined || body.count !== undefined).to.be.true;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Nearby jobs \u2014 missing lat returns 400",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/jobs/nearby/?lng=4.9041"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ]
        },
        {
          "name": "Click job \u2014 anoniem registreert klik",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/jobs/{{job_id}}/click/",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.collectionVariables.get('job_id')) {",
                  "  pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "  pm.test('Returns source_url', () => pm.expect(pm.response.json()).to.have.property('source_url'));",
                  "} else {",
                  "  pm.test('Geen job_id beschikbaar \u2014 skip', () => true);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Click job \u2014 authenticated registreert klik",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/jobs/{{job_id}}/click/",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.collectionVariables.get('job_id')) {",
                  "  pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "  pm.test('Returns source_url', () => pm.expect(pm.response.json()).to.have.property('source_url'));",
                  "} else {",
                  "  pm.test('Geen job_id beschikbaar \u2014 skip', () => true);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Scraped Companies",
      "item": [
        {
