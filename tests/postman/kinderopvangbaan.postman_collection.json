{
  "info": {
    "name": "KinderopvangBaan API",
    "description": "Integration tests for the KinderopvangBaan Django REST API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "{{BASE_URL}}", "type": "string" },
    { "key": "access_token", "value": "", "type": "string" },
    { "key": "refresh_token", "value": "", "type": "string" },
    { "key": "institution_id", "value": "", "type": "string" },
    { "key": "job_id", "value": "", "type": "string" },
    { "key": "worker_username", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Institutions list is accessible",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/institutions/"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns paginated result', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('results');",
                  "  pm.expect(body.results).to.be.an('array');",
                  "});",
                  "if (pm.response.json().results.length > 0) {",
                  "  pm.collectionVariables.set('institution_id', pm.response.json().results[0].id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Jobs list is accessible",
          "request": { "method": "GET", "url": "{{base_url}}/jobs/" },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has results array', () => pm.expect(pm.response.json().results).to.be.an('array'));",
                  "if (pm.response.json().results.length > 0) {",
                  "  pm.collectionVariables.set('job_id', pm.response.json().results[0].id);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth — Register",
      "item": [
        {
          "name": "Register worker",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"username\": \"newman_w_{{$randomInt}}\", \"email\": \"w_{{$randomInt}}@test.nl\", \"password\": \"testpass123\", \"role\": \"worker\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('Returns user data with role', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('id');",
                  "  pm.expect(body.role).to.eql('worker');",
                  "});",
                  "pm.test('No password in response', () => pm.expect(pm.response.json()).to.not.have.property('password'));",
                  "pm.collectionVariables.set('worker_username', pm.response.json().username);"
                ]
              }
            }
          ]
        },
        {
          "name": "Register — short password rejected",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"username\": \"badpw_{{$randomInt}}\", \"password\": \"abc\", \"role\": \"worker\"}" }
          },
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('Status 400', () => pm.response.to.have.status(400));"] }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth — Token",
      "item": [
        {
          "name": "Obtain JWT token",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/token/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"username\": \"{{worker_username}}\", \"password\": \"testpass123\"}" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns access and refresh tokens', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('access');",
                  "  pm.expect(body).to.have.property('refresh');",
                  "});",
                  "pm.collectionVariables.set('access_token', pm.response.json().access);",
                  "pm.collectionVariables.set('refresh_token', pm.response.json().refresh);"
                ]
              }
            }
          ]
        },
        {
          "name": "Wrong password returns 401",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/token/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"username\": \"{{worker_username}}\", \"password\": \"wrongpassword\"}" }
          },
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('Status 401', () => pm.response.to.have.status(401));"] }
            }
          ]
        },
        {
          "name": "Refresh access token",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/token/refresh/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"refresh\": \"{{refresh_token}}\"}" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns new access token', () => pm.expect(pm.response.json()).to.have.property('access'));",
                  "pm.collectionVariables.set('access_token', pm.response.json().access);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth — Me & Profile",
      "item": [
        {
          "name": "GET /me/ — authenticated",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/me/",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns username', () => {",
                  "  pm.expect(pm.response.json().username).to.eql(pm.collectionVariables.get('worker_username'));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /me/ — unauthenticated returns 401",
          "request": { "method": "GET", "url": "{{base_url}}/auth/me/" },
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('Status 401', () => pm.response.to.have.status(401));"] }
            }
          ]
        },
        {
          "name": "GET worker-profile",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/worker-profile/",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has work_radius_km', () => pm.expect(pm.response.json()).to.have.property('work_radius_km'));"
                ]
              }
            }
          ]
        },
        {
          "name": "PATCH worker-profile",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/auth/worker-profile/",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"bio\": \"Newman test bio\", \"work_radius_km\": 20, \"has_vog\": true}" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Bio updated', () => pm.expect(pm.response.json().bio).to.eql('Newman test bio'));",
                  "pm.test('work_radius_km 20', () => pm.expect(pm.response.json().work_radius_km).to.eql(20));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Institutions",
      "item": [
        {
          "name": "Filter by institution_type=bso",
          "request": { "method": "GET", "url": "{{base_url}}/institutions/?institution_type=bso" },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('All results are BSO', () => {",
                  "  pm.response.json().results.forEach(i => pm.expect(i.institution_type).to.eql('bso'));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get institution detail",
          "request": { "method": "GET", "url": "{{base_url}}/institutions/{{institution_id}}/" },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has required fields', () => {",
                  "  ['id','name','institution_type','city','location'].forEach(f => {",
                  "    pm.expect(pm.response.json()).to.have.property(f);",
                  "  });",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Nearby — Amsterdam 50km",
          "request": { "method": "GET", "url": "{{base_url}}/institutions/nearby/?lat=52.3676&lng=4.9041&radius=50" },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns array', () => pm.expect(pm.response.json()).to.be.an('array'));",
                  "pm.test('Items have distance_km', () => {",
                  "  pm.response.json().forEach(i => pm.expect(i).to.have.property('distance_km'));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Nearby — missing lat returns 400",
          "request": { "method": "GET", "url": "{{base_url}}/institutions/nearby/?lng=4.9041" },
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('Status 400', () => pm.response.to.have.status(400));"] }
            }
          ]
        },
        {
          "name": "Reviews for institution",
          "request": { "method": "GET", "url": "{{base_url}}/institutions/{{institution_id}}/reviews/" },
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] }
            }
          ]
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        {
          "name": "Filter by contract_type=fulltime",
          "request": { "method": "GET", "url": "{{base_url}}/jobs/?contract_type=fulltime" },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('All results are fulltime', () => {",
                  "  pm.response.json().results.forEach(j => pm.expect(j.contract_type).to.eql('fulltime'));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get job detail",
          "request": { "method": "GET", "url": "{{base_url}}/jobs/{{job_id}}/" },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has required fields', () => {",
                  "  ['id','title','job_type','contract_type','institution_name'].forEach(f => {",
                  "    pm.expect(pm.response.json()).to.have.property(f);",
                  "  });",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Nearby jobs — Amsterdam 100km",
          "request": { "method": "GET", "url": "{{base_url}}/jobs/nearby/?lat=52.3676&lng=4.9041&radius=100" },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Nearby jobs — missing lat returns 400",
          "request": { "method": "GET", "url": "{{base_url}}/jobs/nearby/?lng=4.9041" },
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('Status 400', () => pm.response.to.have.status(400));"] }
            }
          ]
        },
        {
          "name": "Apply — unauthenticated returns 401",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/jobs/{{job_id}}/apply/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"cover_letter\": \"Test\"}" }
          },
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('Status 401', () => pm.response.to.have.status(401));"] }
            }
          ]
        },
        {
          "name": "Apply — authenticated worker",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/jobs/{{job_id}}/apply/",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"cover_letter\": \"Ik ben erg gemotiveerd!\"}" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Status is pending', () => pm.expect(pm.response.json().status).to.eql('pending'));"
                ]
              }
            }
          ]
        },
        {
          "name": "My applications — no auth returns 401",
          "request": { "method": "GET", "url": "{{base_url}}/jobs/my-applications/" },
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('Status 401', () => pm.response.to.have.status(401));"] }
            }
          ]
        },
        {
          "name": "My applications — authenticated",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/jobs/my-applications/",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has results array', () => pm.expect(pm.response.json()).to.have.property('results'));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Workers",
      "item": [
        {
          "name": "Public workers list",
          "request": { "method": "GET", "url": "{{base_url}}/users/workers/" },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Nearby workers",
          "request": { "method": "GET", "url": "{{base_url}}/users/workers/?lat=52.3676&lng=4.9041&radius=50" },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
