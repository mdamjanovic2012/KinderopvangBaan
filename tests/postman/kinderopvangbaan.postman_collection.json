    {
      "name": "Workers",
      "item": [
        {
          "name": "Public workers list",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/users/workers/"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Nearby workers",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/users/workers/?lat=52.3676&lng=4.9041&radius=50"
          },
          "event": [
            {
              "listen": "test",
